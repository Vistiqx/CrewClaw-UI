# CrewClaw-UI Environment Configuration
# =============================================================================
# This file contains environment variables for CrewClaw-UI.
# Copy this file to .env and edit the values as needed.
#
# Quick setup:
#   cp .env.example .env
#   # UI_ENCRYPTION_KEY will be auto-generated if empty
# =============================================================================

# =============================================================================
# REQUIRED
# =============================================================================

# Encryption key for credentials storage (32 hex characters)
# Auto-generated if left empty during installation
# Example: UI_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1
UI_ENCRYPTION_KEY=

# =============================================================================
# DATA PATHS (auto-configured by setup.sh)
# =============================================================================

# Where CrewClaw-UI stores its database and data files
DATA_PATH=/opt/data/crewclaw/ui

# SQLite database path
DB_PATH=/opt/data/crewclaw/ui/CrewClaw-UI.db

# Business registry JSON file path
REGISTRY_PATH=/opt/data/crewclaw/business-registry.json

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Docker socket path (for container management)
DOCKER_SOCKET=/var/run/docker.sock

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for CrewClaw-UI web interface
UI_PORT=3000

# Host to bind to (0.0.0.0 = all interfaces)
UI_HOST=0.0.0.0

# Log level (debug, info, warn, error)
LOG_LEVEL=info
